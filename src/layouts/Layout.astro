---
import "../styles/global.css";
import { Icon } from 'astro-icon/components'
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Sonic Luminary</title>
	</head>
	<body class="bg-black text-white">
		
	

		<div class="flex">
			<div>
				<header class="">
					<div class="w-72 h-screen flex flex-col px-8 py-10 gap-10 ">
  
  <div class="flex flex-col gap-1">
    <p class="text-gray-300 font-bold text-2xl tracking-tight">Sonic Luminary</p>
    <p class="text-purple-400 font-bold text-xs uppercase tracking-widest">Premium Account</p>
  </div>

  <div class="flex flex-col gap-6">
    <div class="flex items-center gap-4 cursor-pointer">
      <p class="text-lime-500 text-xl">🏠</p>
      <p class="text-lime-500 font-bold text-xs uppercase tracking-widest">Home</p>
    </div>

    <div class="flex items-center gap-4 cursor-pointer opacity-60 hover:opacity-100 transition">
      <p class="text-white text-xl">🔍</p>
      <p class="text-white font-bold text-xs uppercase tracking-widest">Search</p>
    </div>

    <div class="flex items-center gap-4 cursor-pointer opacity-60 hover:opacity-100 transition">
      <p class="text-white text-xl">🎴</p>
      <p class="text-white font-bold text-xs uppercase tracking-widest">Your Library</p>
    </div>
  </div>

  <div class="mt-4">
    <p class="text-gray-500 font-bold text-[10px] uppercase tracking-[0.2em]">Personal Space</p>
  </div>

  <div class="flex flex-col gap-6">
    <div class="flex items-center gap-4 cursor-pointer opacity-60 hover:opacity-100 transition">
      <p class="text-white text-xl">🤍</p>
      <p class="text-white font-bold text-xs uppercase tracking-widest">Liked Songs</p>
    </div>

    <div class="flex items-center gap-4 cursor-pointer opacity-60 hover:opacity-100 transition">
      <p class="text-white text-xl">➕</p>
      <p class="text-white font-bold text-xs uppercase tracking-widest">Create Playlist</p>
    </div>
  </div>

</div>
				</header>
				

			</div>
			<div>
				<slot />
			</div>
			<div>
				current song
			</div>
		</div>

<div class="fixed bottom-0 left-0 w-full bg-[#121212] border-t border-white/5 px-4 py-3 z-50 shadow-2xl">
    <div class="max-w-full mx-auto flex items-center justify-between gap-4">
      
      <div class="flex items-center gap-4 w-[30%] min-w-[180px]">
        <div class="relative group">
          <img 
            id="album-art" 
            src="/cyber-soul-cover.jpg" 
            alt="Portada" 
            class="w-14 h-14 object-cover rounded-md shadow-lg" 
          />
        </div>
        <div class="flex flex-col truncate">
          <p id="title" class="text-white text-sm font-semibold hover:underline cursor-pointer truncate">
            Cyber Soul
          </p>
          <p id="artist" class="text-gray-400 text-xs hover:text-white cursor-pointer truncate">
            The Glitch Factor
          </p>
        </div>
        <button class="text-[#1db954] ml-2 hover:scale-110 transition-transform">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </button>
      </div>

      <div class="flex-1 flex flex-col items-center gap-2 max-w-[40%]">
        <div class="flex items-center gap-6">
          <button class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </button>
          <button class="text-gray-300 hover:text-white transition-colors">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
          </button>
          <button id="play" class="bg-[#1db954] p-3 rounded-full hover:scale-105 transition-transform shadow-[0_0_15px_rgba(29,185,84,0.4)]">
            <svg class="w-5 h-5 text-black fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
          </button>
          <button class="text-gray-300 hover:text-white transition-colors">
            <svg  class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M16 18h2V6h-2zm-9 0l8.5-6L7 6z"/></svg>
          </button>
          <button class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 4h5v.5L6.5 7H9v1H4V7l2.5-2.5H4V4z" /></svg>
          </button>
        </div>

        <div class="w-full flex items-center gap-2 group">
          <p class="text-[11px] text-gray-500 font-medium min-w-[30px] text-right">1:45</p>
          <div class="flex-1 h-1 bg-white/10 rounded-full cursor-pointer relative overflow-hidden">
            <div class="h-full bg-[#1db954] w-[42%] group-hover:bg-[#1ed760]"></div>
          </div>
          <p class="text-[11px] text-gray-500 font-medium min-w-[30px]">4:12</p>
        </div>
      </div>

      <div class="flex items-center gap-4 w-[30%] justify-end">
        <button class="text-gray-400 hover:text-[#1db954] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 19V6l12-3v13M9 10l12-3M9 14l12-3" /></svg>
        </button>
        <button class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
        <div class="flex items-center gap-2 w-28 group">
          <svg class="w-4 h-4 text-gray-400 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15.536 8.464a5 5 0 010 7.072M12 9v6l-5-4H3V9h4l5-4z" /></svg>
          <div class="flex-1 h-1 bg-white/10 rounded-full overflow-hidden">
            <div class="h-full bg-white group-hover:bg-[#1db954] w-2/3"></div>
          </div>
        </div>
        <button class="text-gray-400 hover:text-white transition-colors ml-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 15v6h-6M3 9V3h6" /></svg>
        </button>
      </div>

    </div>
  </div>

  <audio autoplay id="lol" src=""></audio>
	</body>
</html>

<script>
window.addEventListener('playSong', (event) => {
	const song = event.detail.song;
	document.getElementById('album-art').src = song.album.image.url;
	document.getElementById('title').textContent = song.title;
	document.getElementById('artist').textContent = song.author.name;
	document.getElementById('lol').src = song.audio.url;
});

  document.getElementById('play').addEventListener('click', () => {
    const audio = document.getElementById('lol');
    if (audio.paused) {
      audio.play();
    } else {
      audio.pause();
    }
  });
</script>


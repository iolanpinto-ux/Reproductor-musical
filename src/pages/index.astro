---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import Musica from "../components/Musica.astro";

const response = await fetch("https://api.institutoalfa.org/api/songs");
const { songs } = await response.json();
---

<Layout>
	<section>
		<div class="bg-[#0b0b0b] px-8 py-10 flex flex-col md:flex-row gap-6">

  <div class="flex-1 bg-gray-900 rounded-3xl overflow-hidden relative min-h-[400px] flex items-end">
    <img src="/unnamed.png" class="absolute inset-0 w-full h-full object-cover opacity-60" />
    
    <div class="relative p-10 flex flex-col gap-6">
      <div class="bg-[#1db954] px-3 py-1 rounded-sm self-start">
        <p class="text-black text-[10px] font-bold uppercase">Artist Spotlight</p>
      </div>

      <div class="flex flex-col gap-2">
        <p class="text-white text-6xl font-black uppercase leading-none italic">Neon Echoes</p>
        <p class="text-gray-300 text-sm max-w-md">Experience the latest algorithmic masterpiece from the frontier of electronic soul.</p>
      </div>

      <div class="flex gap-4">
        <div class="bg-[#a855f7] px-8 py-3 rounded-full cursor-pointer">
          <p class="text-black font-bold">Play Now</p>
        </div>
        <div class="bg-white/10 px-8 py-3 rounded-full border border-white/20 cursor-pointer">
          <p class="text-white font-bold">Follow</p>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full md:w-80 flex flex-col gap-6">
    
    <div class="bg-[#181818] p-6 rounded-3xl flex flex-col gap-10">
      <div class="flex flex-col gap-1">
        <p class="text-white text-xl font-bold">New Waves</p>
        <p class="text-gray-500 text-xs">Daily Mix 01</p>
      </div>
      <div class="bg-[#1db954] w-10 h-10 rounded-full flex items-center justify-center self-end">
         <div class="w-0 h-0 border-t-[6px] border-t-transparent border-l-[10px] border-l-black border-b-[6px] border-b-transparent ml-1"></div>
      </div>
    </div>

    <div class="bg-[#181818] p-6 rounded-3xl flex flex-col gap-6">
      <p class="text-white text-xl font-bold">Top Charts</p>
      
      <div class="flex items-center justify-between">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full bg-gray-700 border-2 border-[#181818]"></div>
          <div class="w-10 h-10 rounded-full bg-gray-600 border-2 border-[#181818]"></div>
          <div class="w-10 h-10 rounded-full bg-gray-500 border-2 border-[#181818]"></div>
        </div>
        <p class="text-[#1db954] font-bold text-xs">+12 Global</p>
      </div>
    </div>

  </div>
</div>
	</section>
	<section>
		<div class="bg-black px-10 py-12 flex justify-between items-center border-t border-white/10">
  
  <div class="flex flex-col gap-2">
    <p class="text-white text-3xl font-bold tracking-tight">Your Frequency</p>
    <p class="text-gray-500 text-sm">Personalized for Lyra Voss</p>
  </div>

  <a href="#" class="text-[#a855f7] text-xs font-black uppercase tracking-[0.2em] hover:text-white transition-colors">
    SEE ALL
  </a>
</div>
	</section>
	<section class="">
		<div class="gap-6">
			<div>
				<div class="flex py-10 gap-4">
					<div>
						<img src="/unnamed-(1).png" alt="" />
						<div>
							<p class="font-bold">Synthetic Dreams</p>
							<p>Vector Sector</p>
						</div>
					</div>
					<div>
						<img src="/unnamed-(2).png" alt="" />
						<div>
							<p class="font-bold">Midnight Radio</p>
							<p>The Night Walkers</p>
						</div>
					</div>
					<div>
						<img src="/unnamed-(3).png" alt="" />
						<div>
							<p class="font-bold">Cosmic Drift</p>
							<p>Nebula Theory</p>
						</div>
					</div>
					<div>
						<img src="/unnamed-(4).png" alt="" />
						<div>
							<p class="font-bold">Urban Pulse</p>
							<p>Concrete Jungle</p>
						</div>
					</div>
				</div>
				<div class="flex gap-4">
					<div class="flex-1">
						<img src="/unnamed-(5).png" alt="" />
						<div>
							<p class="font-bold">snooo dogg</p>
							<p>I Wanna Love You</p>
						</div>
					</div>
					<div class="flex-1">
						<img src="/unnamed-(6).png" alt="" />
						<div>
							<p class="font-bold">Payphone</p>
							<p>Maroon 5</p>
						</div>
					</div>
					<div class="flex-1">
						<img src="/unnamed-(7).png" alt="" />
						<div>
							<p class="font-bold">Roar</p>
							<p>Katy Perry</p>
						</div>
					</div>
					<div class="flex-1">
						<img src="/unnamed-(8).png" alt="" />
						<div>
							<p class="font-bold">Windflower</p>
							<p>Billie eilish</p>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-4 gap-4">
					{
						songs.map((song) => {
							return <Musica song={song} />;
						})
					}
				</div>
			</div>
		</div>
	</section>
</Layout>
